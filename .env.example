# ===========================================
# Resume Matcher — Docker Environment
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ===========================================
# Port Configuration (host-side)
# ===========================================
FRONTEND_PORT=3211
BACKEND_PORT=3210
# Must match FRONTEND_PORT — used by the backend to reach the frontend for PDF generation
FRONTEND_BASE_URL=http://localhost:3211

# ===========================================
# LLM Configuration
# ===========================================
# Supported providers: openai, anthropic, openrouter, gemini, deepseek, ollama
# Leave blank to configure per-user via the Settings UI instead.
LLM_PROVIDER=
LLM_MODEL=
LLM_API_KEY=

# For Ollama on the host machine (macOS/Windows use host.docker.internal, Linux use host IP):
# LLM_PROVIDER=ollama
# LLM_MODEL=gemma3:4b
# LLM_API_BASE=http://host.docker.internal:11434
#LLM_API_BASE=

# ===========================================
# Authentication
# ===========================================
# Generate a strong random secret: openssl rand -hex 32
JWT_SECRET=change-me-use-a-strong-random-secret

# ===========================================
# Telegram Integration (optional)
# ===========================================
# Only needed if you want Telegram bot support.
# Each user sets their own bot token via the Settings UI.
# TELEGRAM_WEBHOOK_URL: your server's public base URL (used to build per-user webhook URLs)
# TELEGRAM_WEBHOOK_SECRET: shared secret for validating incoming webhook requests
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=change-me-use-a-strong-random-secret
